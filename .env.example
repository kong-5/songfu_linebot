# 對客戶靜音：優先使用後台「LINE 機器人 → 對客戶訊息靜音」勾選（寫入 app_settings.line_suppress_customer_reply）。
# 若從未在後台儲存過該項，才會沿用下列環境變數（方便部署前預設）。
# LINE_SUPPRESS_LINE_REPLIES=1

# Server
PORT=4000
NODE_ENV=development

# Database：未設 DATABASE_URL 時用本機 SQLite；正式環境建議 Supabase（省 Cloud SQL 費用）
# Supabase：Dashboard → Settings → Database → Connection Pooling → Transaction（port 6543）
# DATABASE_URL=postgresql://postgres.xxxxx:你的密碼@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require
# Cloud SQL 舊連線（遷移完成後請改為上面 Supabase 並刪除 Cloud SQL）
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_PATH=./data/songfu.db

# 照片辨識（本機開發時可加，重啟後生效；金鑰請至 GCP 啟用 Cloud Vision API 後取得）
# GOOGLE_CLOUD_VISION_API_KEY=你的金鑰

# 圖片叫貨灰度：true = 略過 Cloud Vision，僅用 Gemini 視覺（需 parse-order-from-image 已接線）
# USE_GEMINI_VISION_ONLY=true
# Few-Shot 範例圖檔目錄（預設專案下 data/few-shot-examples）
# FEW_SHOT_IMAGE_DIR=
