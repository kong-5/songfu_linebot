# 複製本檔為 .env 後填入；金鑰勿 commit。正式部署建議用 Google Secret Manager（見 docs/secret-manager-and-line-rotate.md）。

# --- LINE Bot（至 LINE Developers → Messaging API 取得）---
LINE_CHANNEL_ACCESS_TOKEN=你的_LINE_Channel_access_token
LINE_CHANNEL_SECRET=你的_LINE_Channel_secret
# 本機測試 webhook 可填 ngrok／Cloud Run 網址（勿含尾端 path，實際 path 為 /webhook）
# LINE_WEBHOOK_PATH=https://你的服務.run.app/

# 對客戶靜音：優先後台「LINE 機器人 → 對客戶訊息靜音」；未儲存過才讀下列。
# LINE_SUPPRESS_LINE_REPLIES=1

# Server（本機）
PORT=4000
NODE_ENV=development

# Database：未設 DATABASE_URL 時用本機 SQLite；正式環境建議 Supabase / Cloud SQL
# DATABASE_URL=postgresql://postgres.xxxxx:你的密碼@db.xxxxx.supabase.co:6543/postgres?sslmode=require
DB_PATH=./data/songfu.db

# 照片 OCR（GCP 啟用 Cloud Vision API 後建立 API 金鑰）
# GOOGLE_CLOUD_VISION_API_KEY=

# Gemini（AI Studio / Google AI API 金鑰）
# GOOGLE_GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Cloud Tasks（選用）---
# LINE_USE_CLOUD_TASKS=1
# GCP_PROJECT_ID=
# GCP_LOCATION=asia-east1
# GCP_QUEUE_NAME=line-webhook-queue
# WORKER_URL=https://你的服務.run.app/api/worker/process-line-event
# LINE_WORKER_SECRET=

# --- Cloud Run 部署（npm run deploy）---
# USE_SECRET_MANAGER=1
# SECRET_MANAGER_KEYS=LINE_CHANNEL_ACCESS_TOKEN,LINE_CHANNEL_SECRET,GOOGLE_GEMINI_API_KEY,DATABASE_URL
# PROJECT_ID=你的-gcp-專案-id
# REGION=asia-east1
# REPO=linebot
# IMAGE=linebot
# SERVICE=songfu-line-bot
# 若未設 DATABASE_URL，可改用 Cloud SQL socket：
# INSTANCE=專案:區域:實例名
# DB_PASS=密碼
# DB_NAME=songfu
# DB_USER=postgres
