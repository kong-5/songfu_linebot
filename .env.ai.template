# AI / OCR 設定範本（請複製到 .env 使用，或把需要的鍵貼到現有 .env）
#
# 至少要有其中一種：
# 1) GOOGLE_CLOUD_VISION_API_KEY（OCR）
# 2) GOOGLE_GEMINI_API_KEY 或 GEMINI_API_KEY（Gemini）
#
# 圖片重新辨識若要從 LINE 抓回附件，仍需 LINE_CHANNEL_ACCESS_TOKEN

# --- OCR（Google Cloud Vision）---
GOOGLE_CLOUD_VISION_API_KEY=

# --- Gemini（擇一即可，建議用 GOOGLE_GEMINI_API_KEY）---
GOOGLE_GEMINI_API_KEY=
# GEMINI_API_KEY=

# --- Gemini 模型（可選；未填預設 gemini-2.0-flash）---
# 若主模型 404，可設後援：GEMINI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-1.5-flash-latest
GEMINI_MODEL=gemini-2.0-flash

# --- LINE（重新辨識圖片附件會用到）---
LINE_CHANNEL_ACCESS_TOKEN=

# 設為 1 可關閉「30 秒結單／手動完成」時的整單重辨識（預設會跑，與後台重新辨識同邏輯）
# LINE_SKIP_FINALIZE_FULL_REBUILD=1

# --- 圖片叫貨灰度（與 parse-order-from-image 開關配合）---
# true = 不使用 Cloud Vision OCR，改以 Gemini 視覺為主（舊路保留對照）
# USE_GEMINI_VISION_ONLY=true
# Few-Shot 範例圖檔目錄（預設 data/few-shot-examples）
# FEW_SHOT_IMAGE_DIR=

# --- npm：@google/generative-ai（專案已列於 dependencies）---

